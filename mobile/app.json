{
  "expo": {
    "name": "SecureMemo",
    "slug": "securememo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0a09"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.securememo"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0c0a09"
      },
      "package": "com.anonymous.securememo"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-crypto",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
